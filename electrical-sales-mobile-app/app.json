{
  "expo": {
    "name": "electrical-sales-mobile",
    "slug": "electrical-sales-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "electricalsalesmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to select pickup locations and autofill address fields."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.rajasekhara.electricalsalesmobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "paymentSdk": {
        "enabled": true,
        "sdkScriptUrl": "https://pmt-sdk.testtoucanpay.in/toucanGatewaySdk.js",
        "token": "",
        "terminalNumber": "39734305",
        "merchantNumber": "818995342819955",
        "currencyCode": "INR",
        "orchestrationEnabled": true
      },
      "eas": {
        "projectId": "f1719526-90ee-4255-8f13-bc72cef1efc9"
      },
      "appProfile": "electramart-mobile"
    }
  }
}
