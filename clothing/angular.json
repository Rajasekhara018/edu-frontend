{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "clothing": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/clothing",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.css",
              "src/styles.scss",
              "src/typography.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kb",
                  "maximumError": "60kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            },
            "velvet-vault": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.velvet-vault.ts"
                }
              ],
              "baseHref": "/"
            },
            "urbanloom": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.urbanloom.ts"
                }
              ],
              "baseHref": "/"
            },
            "aurora-attire": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.aurora-attire.ts"
                }
              ],
              "baseHref": "/"
            },
            "house-of-nova": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.house-of-nova.ts"
                }
              ],
              "baseHref": "/"
            },
            "maple-thread": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.maple-thread.ts"
                }
              ],
              "baseHref": "/"
            },
            "cobalt-closet": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.cobalt-closet.ts"
                }
              ],
              "baseHref": "/"
            },
            "drift-label": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.drift-label.ts"
                }
              ],
              "baseHref": "/"
            },
            "solstice-wear": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.solstice-wear.ts"
                }
              ],
              "baseHref": "/"
            },
            "prism-wardrobe": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prism-wardrobe.ts"
                }
              ],
              "baseHref": "/"
            },
            "ember-lane": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.ember-lane.ts"
                }
              ],
              "baseHref": "/"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "clothing:build"
          },
          "configurations": {
            "production": {
              "buildTarget": "clothing:build:production"
            },
            "development": {
              "buildTarget": "clothing:build:development"
            },
            "velvet-vault": {
              "buildTarget": "clothing:build:velvet-vault"
            },
            "urbanloom": {
              "buildTarget": "clothing:build:urbanloom"
            },
            "aurora-attire": {
              "buildTarget": "clothing:build:aurora-attire"
            },
            "house-of-nova": {
              "buildTarget": "clothing:build:house-of-nova"
            },
            "maple-thread": {
              "buildTarget": "clothing:build:maple-thread"
            },
            "cobalt-closet": {
              "buildTarget": "clothing:build:cobalt-closet"
            },
            "drift-label": {
              "buildTarget": "clothing:build:drift-label"
            },
            "solstice-wear": {
              "buildTarget": "clothing:build:solstice-wear"
            },
            "prism-wardrobe": {
              "buildTarget": "clothing:build:prism-wardrobe"
            },
            "ember-lane": {
              "buildTarget": "clothing:build:ember-lane"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "clothing:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.css",
              "src/styles.scss",
              "src/typography.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}