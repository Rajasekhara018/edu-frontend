{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "webSite": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/web-site",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.css",
              "src/styles.scss",
              "src/typography.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "edusoft": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.edusoft.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/",
              "optimization": true,
              "sourceMap": false,
              "namedChunks": false,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "10mb",
                  "maximumError": "5mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "outputHashing": "all"
            },
            "aurora-tech": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.aurora-tech.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "bluecrest-learning": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.bluecrest-learning.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "catalyst-academy": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.catalyst-academy.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "codeharbor": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.codeharbor.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "datanova-institute": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.datanova-institute.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "elevate-labs": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.elevate-labs.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "futureforge": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.futureforge.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "growthgrid-academy": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.growthgrid-academy.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "igniteverse": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.igniteverse.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "nextorbit-learning": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.nextorbit-learning.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "quantum-skillhouse": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.quantum-skillhouse.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "vertex-academy": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.vertex-academy.ts"
                }
              ],
              "baseHref": "/",
              "deployUrl": "/"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "browserTarget": "webSite:build:production"
            },
            "development": {
              "browserTarget": "webSite:build:development"
            },
            "edusoft": {
              "browserTarget": "webSite:build:edusoft"
            },
            "aurora-tech": {
              "browserTarget": "webSite:build:aurora-tech"
            },
            "bluecrest-learning": {
              "browserTarget": "webSite:build:bluecrest-learning"
            },
            "catalyst-academy": {
              "browserTarget": "webSite:build:catalyst-academy"
            },
            "codeharbor": {
              "browserTarget": "webSite:build:codeharbor"
            },
            "datanova-institute": {
              "browserTarget": "webSite:build:datanova-institute"
            },
            "elevate-labs": {
              "browserTarget": "webSite:build:elevate-labs"
            },
            "futureforge": {
              "browserTarget": "webSite:build:futureforge"
            },
            "growthgrid-academy": {
              "browserTarget": "webSite:build:growthgrid-academy"
            },
            "igniteverse": {
              "browserTarget": "webSite:build:igniteverse"
            },
            "nextorbit-learning": {
              "browserTarget": "webSite:build:nextorbit-learning"
            },
            "quantum-skillhouse": {
              "browserTarget": "webSite:build:quantum-skillhouse"
            },
            "vertex-academy": {
              "browserTarget": "webSite:build:vertex-academy"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "webSite:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "src/favicon.ico",
              "src/assets"
            ],
            "styles": [
              "node_modules/@angular/material/prebuilt-themes/indigo-pink.css",
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "node_modules/bootstrap-icons/font/bootstrap-icons.css",
              "src/styles.scss",
              "src/typography.scss"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
